---
import { billReviewCopyText, findBillReviewTarget } from '../../../../lib/billReview';
import { formatMoney } from '../../../../lib/money';
import { fireflyBillHref, loadDashboardData } from '../../../../server/dashboard';
import '../../../../styles/global.css';

const requestUrl = new URL(Astro.request.url);
const billId = requestUrl.searchParams.get('billId')?.trim() ?? '';
const month = requestUrl.searchParams.get('month');
const fireflyHref = billId ? fireflyBillHref(billId) : undefined;
let loadError: string | null = null;
let target = null;

if (!billId || !fireflyHref) {
  Astro.response.status = 400;
} else {
  try {
    const dashboardData = await loadDashboardData({ month });
    target = findBillReviewTarget({ billId, groups: dashboardData.expected });
  } catch (error) {
    Astro.response.status = 400;
    loadError = error instanceof Error ? error.message : 'Bill review could not be loaded';
  }
}

const title = target?.event.name ?? (billId ? `Bill ${billId}` : 'Bill review');
const dashboardHref = month ? `/months/${encodeURIComponent(month)}` : '/';
const statusLabel = target?.statusLabel ?? (loadError ?? 'Bill unavailable');
const statusTone = target ? `tone-${target.event.tone}` : 'tone-watch';
const copyText =
  target ?
    billReviewCopyText({ fireflyHref, target })
  : [`Firefly bill: ${billId || 'Missing'}`, fireflyHref ? `Open in Firefly: ${fireflyHref}` : null].filter(Boolean).join('\n');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Bill review prep for Firefly III." />
    <title>{title} · Bill review</title>
  </head>
  <body>
    <main class="action-shell">
      <section class="action-panel" aria-labelledby="action-title">
        <a class="action-back" href={dashboardHref}>Back to dashboard</a>
        <header class="action-header">
          <span class={`status-chip ${statusTone}`}>{statusLabel}</span>
          <h1 id="action-title">{title}</h1>
          <p>{target?.groupLabel ?? 'Firefly bill'} · {billId || 'No bill id'}</p>
        </header>

        {target ? (
          <>
            <section class="action-summary-grid" aria-label="Bill summary">
              <div>
                <span>Expected</span>
                <strong>{formatMoney(target.event.expected)}</strong>
              </div>
              <div>
                <span>Open</span>
                <strong>{formatMoney(target.openAmount)}</strong>
              </div>
              <div>
                <span>Due</span>
                <strong>{target.event.due}</strong>
              </div>
            </section>

            <section class="action-fix-stack" aria-label="Bill review guidance">
              <div>
                <span>Review path</span>
                <strong>{target.guidance}</strong>
              </div>
              <div class="action-fix-brief">
                <span>
                  <strong>Group</strong>
                  {target.groupLabel}
                </span>
                <span>
                  <strong>Status</strong>
                  {target.statusLabel}
                </span>
                <span>
                  <strong>ID</strong>
                  {target.billId}
                </span>
              </div>
            </section>

            <section class="action-copy-block" aria-label="Bill review note">
              <pre>{copyText}</pre>
            </section>

            <section class="action-category-panel" aria-label="Bill resolution">
              <header>
                <span>Firefly handoff</span>
                <h2>Resolve bill warning</h2>
                <p>{target.action}</p>
              </header>
              <div class={`action-notice ${target.event.tone === 'ok' ? 'tone-ok' : 'tone-watch'}`}>
                <strong>{target.event.tone === 'ok' ? 'No warning' : 'Review needed'}</strong>
                <span>{target.guidance}</span>
              </div>
            </section>
          </>
        ) : (
          <>
            <section class="empty-state action-empty">
              <strong>Bill not found</strong>
              <p>This bill is not in the current expected cashflow data. Open Firefly to inspect the bill record.</p>
            </section>
            {fireflyHref && (
              <div class="action-notice tone-watch">
                <strong>Bill review unavailable</strong>
                <span>The dashboard has no matching expected item for this bill id.</span>
                <a href={fireflyHref}>Open bill in Firefly</a>
              </div>
            )}
          </>
        )}

        <div class="action-buttons">
          {fireflyHref && <a class="primary-action" href={fireflyHref}>Continue in Firefly</a>}
          {target && (
            <button type="button" data-copy-fix={copyText} aria-label={`Copy bill note for ${target.event.name}`}>
              Copy bill note
            </button>
          )}
          <a href={dashboardHref}>Dashboard</a>
          <span class="action-copy-feedback" data-copy-feedback aria-live="polite"></span>
        </div>
      </section>
    </main>
    <script>
      const copyButton = document.querySelector('button[data-copy-fix]');
      const copyFeedback = document.querySelector('[data-copy-feedback]');

      if (copyButton instanceof HTMLButtonElement && copyFeedback instanceof HTMLElement) {
        copyButton.addEventListener('click', async () => {
          const copyText = copyButton.getAttribute('data-copy-fix') ?? '';

          try {
            await navigator.clipboard.writeText(copyText);
            copyFeedback.textContent = 'Copied';
            copyButton.setAttribute('aria-label', 'Copied bill note');
          } catch {
            copyFeedback.textContent = 'Copy unavailable';
          }
        });
      }
    </script>
  </body>
</html>
