---
import { accountReviewCopyText, findAccountReviewTarget } from '../../../../lib/accountReview';
import { formatMoney } from '../../../../lib/money';
import { fireflyAccountHref, loadDashboardData } from '../../../../server/dashboard';
import '../../../../styles/global.css';

const requestUrl = new URL(Astro.request.url);
const accountId = requestUrl.searchParams.get('accountId')?.trim() ?? '';
const month = requestUrl.searchParams.get('month');
const fireflyHref = accountId ? fireflyAccountHref(accountId) : undefined;
let loadError: string | null = null;
let target = null;

if (!accountId || !fireflyHref) {
  Astro.response.status = 400;
} else {
  try {
    const dashboardData = await loadDashboardData({ month });
    target = findAccountReviewTarget({ accountId, data: dashboardData });
  } catch (error) {
    Astro.response.status = 400;
    loadError = error instanceof Error ? error.message : 'Account review could not be loaded';
  }
}

const title = target?.account.name ?? (accountId ? `Account ${accountId}` : 'Account review');
const dashboardHref = month ? `/months/${encodeURIComponent(month)}` : '/';
const statusLabel = target?.statusLabel ?? (loadError ?? 'Account unavailable');
const statusTone = target ? `tone-${target.tone}` : 'tone-watch';
const copyText =
  target ?
    accountReviewCopyText({ fireflyHref, target })
  : [`Firefly account: ${accountId || 'Missing'}`, fireflyHref ? `Open: ${fireflyHref}` : null].filter(Boolean).join('\n');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Account review prep for Firefly III." />
    <title>{title} · Account review</title>
  </head>
  <body>
    <main class="action-shell">
      <section class="action-panel" aria-labelledby="action-title">
        <a class="action-back" href={dashboardHref}>Back to dashboard</a>
        <header class="action-header">
          <span class={`status-chip ${statusTone}`}>{statusLabel}</span>
          <h1 id="action-title">{title}</h1>
          <p>{target?.groupLabel ?? 'Firefly account'} · {accountId || 'No account id'}</p>
        </header>

        {target ? (
          <>
            <section class="action-summary-grid" aria-label="Account summary">
              <div>
                <span>Balance</span>
                <strong>{formatMoney(target.account.balance)}</strong>
              </div>
              <div>
                <span>Type</span>
                <strong>{target.account.kind}</strong>
              </div>
              <div>
                <span>Freshness</span>
                <strong>{target.account.freshness}</strong>
              </div>
            </section>

            <section class="action-fix-stack" aria-label="Account review guidance">
              <div>
                <span>Review path</span>
                <strong>{target.guidance}</strong>
              </div>
              <div class="action-fix-brief">
                <span>
                  <strong>Group</strong>
                  {target.groupLabel}
                </span>
                <span>
                  <strong>Status</strong>
                  {target.statusLabel}
                </span>
                <span>
                  <strong>ID</strong>
                  {target.accountId}
                </span>
              </div>
            </section>

            <section class="action-copy-block" aria-label="Account review note">
              <pre>{copyText}</pre>
            </section>

            <section class="action-category-panel" aria-label="Account resolution">
              <header>
                <span>Firefly handoff</span>
                <h2>Resolve account warning</h2>
                <p>{target.action}</p>
              </header>
              <div class={`action-notice ${target.tone === 'watch' || target.tone === 'risk' ? 'tone-watch' : 'tone-ok'}`}>
                <strong>{target.tone === 'watch' || target.tone === 'risk' ? 'Review needed' : 'No warning'}</strong>
                <span>{target.guidance}</span>
              </div>
            </section>
          </>
        ) : (
          <>
            <section class="empty-state action-empty">
              <strong>Account not found</strong>
              <p>This account is not in the current Money Map. Open Firefly to inspect the ledger record.</p>
            </section>
            {fireflyHref && (
              <div class="action-notice tone-watch">
                <strong>Account review unavailable</strong>
                <span>The dashboard has no matching account row for this id.</span>
                <a href={fireflyHref}>Open account in Firefly</a>
              </div>
            )}
          </>
        )}

        <div class="action-buttons">
          {fireflyHref && <a class="primary-action" href={fireflyHref}>Continue in Firefly</a>}
          {target && (
            <button type="button" data-copy-fix={copyText} aria-label={`Copy account note for ${target.account.name}`}>
              Copy account note
            </button>
          )}
          <a href={dashboardHref}>Dashboard</a>
          <span class="action-copy-feedback" data-copy-feedback aria-live="polite"></span>
        </div>
      </section>
    </main>
    <script>
      const copyButton = document.querySelector('button[data-copy-fix]');
      const copyFeedback = document.querySelector('[data-copy-feedback]');

      if (copyButton instanceof HTMLButtonElement && copyFeedback instanceof HTMLElement) {
        copyButton.addEventListener('click', async () => {
          const copyText = copyButton.getAttribute('data-copy-fix') ?? '';

          try {
            await navigator.clipboard.writeText(copyText);
            copyFeedback.textContent = 'Copied';
            copyButton.setAttribute('aria-label', 'Copied account note');
          } catch {
            copyFeedback.textContent = 'Copy unavailable';
          }
        });
      }
    </script>
  </body>
</html>
