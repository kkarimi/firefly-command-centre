---
import type { DashboardData, ReviewItem } from '../../../../data/fixtures';
import { formatSignedMoney } from '../../../../lib/money';
import { reviewClipboardText, reviewFixBrief } from '../../../../lib/reviewFix';
import {
  loadFireflyCategoryOptions,
  updateTransactionCategory,
  type CategoryFixResult,
  type FireflyCategoryOption,
} from '../../../../server/fireflyActions';
import { fireflyTransactionActionHref, loadDashboardData } from '../../../../server/dashboard';
import '../../../../styles/global.css';

const requestUrl = new URL(Astro.request.url);
const groupId = requestUrl.searchParams.get('groupId')?.trim() ?? '';
const month = requestUrl.searchParams.get('month');
const fireflyEditHref = groupId ? fireflyTransactionActionHref(groupId) : undefined;
let dashboardData: DashboardData | null = null;
let reviewItem: ReviewItem | undefined;
let loadError: string | null = null;
let categoryOptions: FireflyCategoryOption[] = [];
let categoryLoadError: string | null = null;
let categoryFixResult: CategoryFixResult | null = null;
let submittedCategoryId = '';

if (!groupId || !fireflyEditHref) {
  Astro.response.status = 400;
} else {
  try {
    dashboardData = await loadDashboardData({ month });
    reviewItem = dashboardData.reviewItems.find((item) => item.fireflyGroupId === groupId);

    if (Astro.request.method === 'POST' && reviewItem) {
      const formData = await Astro.request.formData();
      submittedCategoryId = formData.get('categoryId')?.toString() ?? '';
      const transactionJournalId = reviewItem.fireflyJournalId ?? '';
      categoryFixResult = await updateTransactionCategory({
        categoryId: submittedCategoryId,
        confirmed: formData.get('confirmCategoryWrite') === 'yes',
        groupId,
        transactionJournalId,
      });

      if (categoryFixResult.ok) {
        dashboardData = await loadDashboardData({ bypassCache: true, month });
        reviewItem = dashboardData.reviewItems.find((item) => item.fireflyGroupId === groupId) ?? reviewItem;
      }
    }
  } catch (error) {
    Astro.response.status = 400;
    loadError = error instanceof Error ? error.message : 'Review item could not be loaded';
  }

  try {
    categoryOptions = await loadFireflyCategoryOptions();
  } catch (error) {
    categoryLoadError = error instanceof Error ? error.message : 'Firefly categories could not be loaded';
  }
}

const fixBrief = reviewItem ? reviewFixBrief(reviewItem) : [];
const title = reviewItem?.payee ?? (groupId ? `Transaction ${groupId}` : 'Transaction review');
const dashboardHref = month ? `/months/${encodeURIComponent(month)}` : '/';
const suggestedCategoryName = fixBrief.find((entry) => entry.label === 'Category')?.value ?? '';
const suggestedCategory = suggestedCategoryName
  ? categoryOptions.find((category) => category.name.toLowerCase() === suggestedCategoryName.toLowerCase())
  : undefined;
const selectedCategoryId = submittedCategoryId || suggestedCategory?.id || '';
const hasFireflyJournalId = Boolean(reviewItem?.fireflyJournalId);
const categoryWriteAvailable = reviewItem && hasFireflyJournalId && categoryOptions.length > 0;
if (!categoryWriteAvailable && reviewItem && !loadError && !categoryLoadError) {
  if (!hasFireflyJournalId) {
    categoryLoadError = 'Firefly did not return the split ID needed for an in-app save.';
  } else if (categoryOptions.length === 0) {
    categoryLoadError = 'No Firefly categories were available from the API.';
  }
}
const statusLabel = categoryFixResult?.ok ? categoryFixResult.message : (reviewItem?.reason ?? (loadError ?? 'Review row unavailable'));
const statusTone = categoryFixResult?.ok ? 'tone-ok' : reviewItem ? `tone-${reviewItem.severity}` : 'tone-watch';
const copyText = reviewItem
  ? reviewClipboardText({ ...reviewItem, fireflyEditHref })
  : [`Firefly group: ${groupId || 'Missing'}`, fireflyEditHref ? `Open: ${fireflyEditHref}` : null].filter(Boolean).join('\n');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Transaction review prep for Firefly III." />
    <title>{title} · Fix prep</title>
  </head>
  <body>
    <main class="action-shell">
      <section class="action-panel" aria-labelledby="action-title">
        <a class="action-back" href={dashboardHref}>Back to dashboard</a>
        <header class="action-header">
          <span class={`status-chip ${statusTone}`}>{statusLabel}</span>
          <h1 id="action-title">{title}</h1>
          <p>{dashboardData?.period.label ?? 'Firefly transaction'} · {groupId || 'No group id'}</p>
        </header>

        {reviewItem ? (
          <>
            <section class="action-summary-grid" aria-label="Transaction summary">
              <div>
                <span>Amount</span>
                <strong>{formatSignedMoney(reviewItem.amount)}</strong>
              </div>
              <div>
                <span>Source</span>
                <strong>{reviewItem.source}</strong>
              </div>
              <div>
                <span>Age</span>
                <strong>{reviewItem.ageDays}d</strong>
              </div>
            </section>

            <section class="action-fix-stack" aria-label="Fix checklist">
              <div>
                <span>Suggested fix</span>
                <strong>{reviewItem.suggestion}</strong>
              </div>
              {fixBrief.length > 0 && (
                <div class="action-fix-brief">
                  {fixBrief.map((entry) => (
                    <span>
                      <strong>{entry.label}</strong>
                      {entry.value}
                    </span>
                  ))}
                </div>
              )}
            </section>

            <section class="action-copy-block" aria-label="Review fix note">
              <pre>{copyText}</pre>
            </section>

            <section class="action-category-panel" aria-label="Set category in Firefly">
              <header>
                <span>Firefly write</span>
                <h2>Set category here</h2>
                <p>Updates this transaction in Firefly using an existing category only.</p>
              </header>

              {categoryFixResult && (
                <div class={`action-notice ${categoryFixResult.ok ? 'tone-ok' : 'tone-risk'}`}>
                  <strong>{categoryFixResult.ok ? 'Saved' : 'Not saved'}</strong>
                  <span>{categoryFixResult.message}</span>
                </div>
              )}

              {categoryWriteAvailable ? (
                <form method="post" class="category-fix-form">
                  <label>
                    <span>Category</span>
                    <select
                      name="categoryId"
                      data-category-select
                      data-current-category-id={reviewItem.categoryId ?? ''}
                      data-current-category-name={reviewItem.categoryName ?? ''}
                      required
                    >
                      <option value="">Choose category</option>
                      {categoryOptions.map((category) => (
                        <option value={category.id} selected={category.id === selectedCategoryId}>
                          {category.name}
                        </option>
                      ))}
                    </select>
                    {reviewItem.categoryName && <small>Current: {reviewItem.categoryName}</small>}
                  </label>
                  <label class="category-write-confirm">
                    <input type="checkbox" name="confirmCategoryWrite" value="yes" data-category-confirm required />
                    <span>Save this category to Firefly for this transaction.</span>
                  </label>
                  <small data-category-status hidden>Choose a different category.</small>
                  <button type="submit" data-category-submit>Save category</button>
                </form>
              ) : (
                <div class="action-notice tone-watch">
                  <strong>Category save unavailable</strong>
                  <span>{categoryLoadError ?? 'Use Firefly for this edit until categories load here.'}</span>
                  {fireflyEditHref && <a href={fireflyEditHref}>Open transaction editor</a>}
                </div>
              )}
            </section>
          </>
        ) : (
          <section class="empty-state action-empty">
            <strong>Review row not found</strong>
            <p>This transaction is not in the selected review queue.</p>
          </section>
        )}

        <div class="action-buttons">
          {fireflyEditHref && <a class="primary-action" href={fireflyEditHref}>Continue in Firefly</a>}
          {reviewItem && (
            <button type="button" data-copy-fix={copyText} aria-label={`Copy fix note for ${reviewItem.payee}`}>
              Copy fix note
            </button>
          )}
          <a href={dashboardHref}>Dashboard</a>
          <span class="action-copy-feedback" data-copy-feedback aria-live="polite"></span>
        </div>
      </section>
    </main>
    <script>
      const copyButton = document.querySelector('button[data-copy-fix]');
      const copyFeedback = document.querySelector('[data-copy-feedback]');
      const categorySelect = document.querySelector('select[data-category-select]');
      const categoryConfirm = document.querySelector('input[data-category-confirm]');
      const categorySubmit = document.querySelector('button[data-category-submit]');
      const categoryStatus = document.querySelector('[data-category-status]');

      if (copyButton instanceof HTMLButtonElement && copyFeedback instanceof HTMLElement) {
        copyButton.addEventListener('click', async () => {
          const copyText = copyButton.getAttribute('data-copy-fix') ?? '';

          try {
            await navigator.clipboard.writeText(copyText);
            copyFeedback.textContent = 'Copied';
            copyButton.setAttribute('aria-label', 'Copied fix note');
          } catch {
            copyFeedback.textContent = 'Copy unavailable';
          }
        });
      }

      if (
        categorySelect instanceof HTMLSelectElement &&
        categoryConfirm instanceof HTMLInputElement &&
        categorySubmit instanceof HTMLButtonElement
      ) {
        const currentCategoryId = categorySelect.getAttribute('data-current-category-id') ?? '';
        const currentCategoryName = (categorySelect.getAttribute('data-current-category-name') ?? '').trim().toLowerCase();

        const syncCategorySubmit = () => {
          const selectedOption = categorySelect.selectedOptions[0];
          const selectedCategoryName = selectedOption?.textContent?.trim().toLowerCase() ?? '';
          const hasSelection = categorySelect.value !== '';
          const selectsCurrentCategory =
            hasSelection &&
            ((currentCategoryId && categorySelect.value === currentCategoryId) ||
              (currentCategoryName && selectedCategoryName === currentCategoryName));

          categorySubmit.disabled = !hasSelection || selectsCurrentCategory || !categoryConfirm.checked;

          if (categoryStatus instanceof HTMLElement) {
            categoryStatus.hidden = !selectsCurrentCategory;
          }
        };

        categorySelect.addEventListener('change', syncCategorySubmit);
        categoryConfirm.addEventListener('change', syncCategorySubmit);
        syncCategorySubmit();
      }
    </script>
  </body>
</html>
