{
  "name": "firefly-finance-ui",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "lint": "oxlint . --max-warnings 0",
    "lint:react": "react-doctor . --yes --no-telemetry --blocking error --no-warnings",
    "doctor": "react-doctor . --yes --no-telemetry --blocking warning",
    "build": "astro build",
    "check": "astro check",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "bun run lint && bun run lint:react && bun run check && bun run test && bun run build && bun run test:e2e"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.0",
    "@astrojs/react": "^6.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.3",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "oxlint": "^1.71.0",
    "react-doctor": "^0.5.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
